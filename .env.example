# Supabase (https://supabase.com/dashboard/project/_/settings/api)
PUBLIC_SUPABASE_URL=
# Use the anon (legacy) key or a publishable key from the dashboard Connect dialog.
PUBLIC_SUPABASE_ANON_KEY=

# Optional: new-style publishable key (if you prefer it for client-side calls)
# PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only: never expose to the browser. Use only in hooks/+server/admin scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Dashboard → Authentication → URL Configuration:
# Add redirect URLs (local + production), e.g.:
# http://localhost:5173/auth/callback
# https://YOUR_DOMAIN/auth/callback
